# Railway provides DATABASE_URL automatically when you link Postgres
DATABASE_URL=postgresql://user:password@host:port/dbname

# Auth
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=https://cryptiq-xi.vercel.app

# Redis (optional for now — Railway provides REDIS_URL when you add Redis)
# REDIS_URL=redis://default:password@host:port
